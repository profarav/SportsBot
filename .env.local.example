# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (get at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Weaviate RAG (enables semantic search over game logs) ────────────
# Create a free cluster at console.weaviate.cloud
WEAVIATE_URL=https://your-cluster.weaviate.network
WEAVIATE_API_KEY=your-weaviate-api-key

# OpenAI key — used by Weaviate's text2vec-openai vectorizer for embeddings
OPENAI_API_KEY=sk-...

# Secret for the /api/ingest endpoint (any random string)
INGEST_SECRET=change-me-to-a-random-secret
